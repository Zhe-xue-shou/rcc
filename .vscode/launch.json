{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      // codelldb provide better support as for breakpoint
      "name": "codelldb debug rcns",
      "cwd": "${workspaceFolder}",
      // "program": "${workspaceFolder}/target/debug/rcns.exe",
      // "preLaunchTask": "rust: cargo build",
      "cargo": {
        "args": [
          "build"
        ],
        "filter": {
          "name": "rcns",
          "kind": "bin"
        }
      },
      "console": "internalConsole",
      "stopOnEntry": false,
      "sourceLanguages": [
        "rust"
      ],
    },
    {
      "type": "lldb-dap",
      "request": "launch",
      // lldb-dap is more friendly as for debug console
      "name": "lldb-dap debug rcns",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/target/debug/rcns.exe",
      "preLaunchTask": "rust: cargo build",
      "console": "internalConsole",
      "stopOnEntry": false,
    },
  ]
}