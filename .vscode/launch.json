{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      // codelldb provide better support as for breakpoint
      "name": "codelldb debug rcc",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/target/debug/rcc.exe",
      "preLaunchTask": "rust: cargo build",
      "cargo": {
        "args": [
          "build"
        ],
        "filter": {
          "name": "rcc",
          "kind": "bin"
        }
      },
      "console": "internalConsole",
      "stopOnEntry": false,
      "sourceLanguages": [
        "rust"
      ],
    },
    // {
    //   "type": "lldb-dap",
    //   "request": "launch",
    //   // lldb-dap is more friendly as for debug console
    //   "name": "lldb-dap debug rcc",
    //   "cwd": "${workspaceFolder}",
    //   "program": "${workspaceFolder}/target/debug/rcc.exe",
    //   "preLaunchTask": "rust: cargo build",
    //   "console": "internalConsole",
    //   "stopOnEntry": false,
    // },
    {
      "type": "lldb-dap",
      "request": "launch",
      "name": "cargo run -p rcc",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}\\target\\debug\\rcc.exe",
      "env": [
        "RUST_BACKTRACE=short",
        "RUSTC_TOOLCHAIN=Z:\\.packages\\.rustup\\toolchains\\nightly-x86_64-pc-windows-msvc"
      ],
      "args": []
    }
  ]
}